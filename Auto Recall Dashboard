function buildFiChart() {
  const container = document.getElementById('fiChart');
  if (!container) return;
  const maxScore = fiData[0].score;
  let html = '';
  fiData.forEach(f => {
    const pct = (f.score / maxScore) * 95;
    const scorePct = (f.score * 100).toFixed(2) + '%';
    html += `
      <div class="fi-row">
        <span class="fi-rank">${f.rank}</span>
        <span class="fi-name" title="${f.name}">${f.name}</span>
        <div class="fi-bar-wrap">
          <div class="fi-bar ${f.type}" style="width:${pct}%">${scorePct}</div>
          <div class="fi-tooltip">${f.desc}</div>
        </div>
      </div>`;
  });
  container.innerHTML = html;
}

