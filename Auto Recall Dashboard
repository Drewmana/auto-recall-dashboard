<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Riverdale Investments — Strategic Recall Analysis</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --red: #CC0000; --red-dark: #990000; --red-light: #ff3333;
  --navy: #002654; --navy-light: #003580; --navy-dark: #001a3a;
  --gold: #9E7C0C; --gold-light: #c9a227;
  --white: #ffffff; --off-white: #f8f8f8;
  --gray-light: #f0f0f0; --gray: #e0e0e0; --gray-mid: #999; --gray-dark: #444;
  --text: #1a1a1a; --green: #1a7a3f; --green-light: #e8f5ee;
}
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { font-family:'DM Sans',sans-serif; background:var(--off-white); color:var(--text); overflow-x:hidden; }

/* NAV */
nav {
  position:fixed; top:0; left:0; right:0; z-index:1000;
  background:var(--navy-dark); border-bottom:3px solid var(--red);
  display:flex; align-items:center; justify-content:space-between;
  padding:0 2rem; height:60px;
}
.nav-brand { display:flex; align-items:center; gap:12px; }
.nav-logo {
  width:36px; height:36px; background:var(--red); border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-family:'Playfair Display',serif; font-weight:900; color:white; font-size:16px;
}
.nav-title { font-family:'Playfair Display',serif; font-weight:700; color:white; font-size:1rem; }
.nav-links { display:flex; gap:0; list-style:none; }
.nav-links a {
  color:rgba(255,255,255,0.75); text-decoration:none; font-size:0.75rem;
  font-weight:500; letter-spacing:0.5px; padding:0 12px; height:60px;
  display:flex; align-items:center; transition:all 0.2s;
  border-bottom:3px solid transparent; margin-bottom:-3px; text-transform:uppercase;
}
.nav-links a:hover, .nav-links a.active { color:white; border-bottom-color:var(--red); background:rgba(255,255,255,0.05); }

/* HAMBURGER */
.hamburger {
  display:none; flex-direction:column; gap:5px;
  background:none; border:none; cursor:pointer; padding:8px;
}
.hamburger span { display:block; width:24px; height:2px; background:white; border-radius:2px; transition:all 0.3s; }
.mobile-menu {
  display:none; flex-direction:column; position:fixed;
  top:60px; left:0; right:0; background:var(--navy-dark);
  border-bottom:3px solid var(--red); z-index:999; padding:0.5rem 0;
}
.mobile-menu.open { display:flex; }
.mobile-menu a {
  color:rgba(255,255,255,0.8); text-decoration:none; padding:0.9rem 2rem;
  font-size:0.9rem; font-weight:500; border-bottom:1px solid rgba(255,255,255,0.06);
  transition:all 0.2s;
}
.mobile-menu a:hover, .mobile-menu a.active { background:rgba(255,255,255,0.08); color:white; }

/* HERO */
#hero {
  min-height:100vh; padding-top:60px;
  background:linear-gradient(135deg,var(--navy-dark) 0%,var(--navy) 50%,#003d7a 100%);
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  text-align:center; padding:80px 2rem 4rem; position:relative; overflow:hidden;
}
#hero::before {
  content:''; position:absolute; top:-50%; left:-50%; width:200%; height:200%;
  background:radial-gradient(ellipse at 30% 40%,rgba(204,0,0,0.12) 0%,transparent 60%),
              radial-gradient(ellipse at 70% 60%,rgba(158,124,12,0.08) 0%,transparent 60%);
  animation:pulse 8s ease-in-out infinite alternate;
}
@keyframes pulse { from{transform:scale(1);opacity:0.7;} to{transform:scale(1.1);opacity:1;} }
.hero-badge {
  background:rgba(204,0,0,0.2); border:1px solid rgba(204,0,0,0.5); color:#ff9999;
  font-size:0.75rem; font-weight:600; letter-spacing:2px; text-transform:uppercase;
  padding:6px 18px; border-radius:20px; margin-bottom:1.5rem; position:relative;
}
#hero h1 {
  font-family:'Playfair Display',serif; font-weight:900;
  font-size:clamp(2.5rem,6vw,5rem); color:white; line-height:1.1;
  margin-bottom:1rem; position:relative;
}
#hero h1 span { color:var(--red-light); }
.hero-subtitle {
  font-size:1.15rem; color:rgba(255,255,255,0.7); max-width:680px;
  margin:0 auto 1rem; line-height:1.6; position:relative;
}
.hero-course { font-size:0.9rem; color:rgba(255,255,255,0.5); margin-bottom:2.5rem; position:relative; }
.hero-metrics {
  display:flex; gap:1px; background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.15); border-radius:12px;
  overflow:hidden; margin-bottom:2rem; position:relative;
}
.hero-metric { padding:1.2rem 1.8rem; background:rgba(0,38,84,0.6); flex:1; min-width:100px; backdrop-filter:blur(10px); }
.hero-metric:not(:last-child) { border-right:1px solid rgba(255,255,255,0.1); }
.hero-metric .val { font-family:'DM Mono',monospace; font-size:1.8rem; font-weight:500; color:white; display:block; }
.hero-metric .val.green { color:#4ade80; }
.hero-metric .val.red { color:#f87171; }
.hero-metric .lbl { font-size:0.7rem; text-transform:uppercase; letter-spacing:1px; color:rgba(255,255,255,0.5); margin-top:2px; display:block; }
.thesis-box {
  background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.12);
  border-left:4px solid var(--red); border-radius:8px; padding:1.2rem 1.8rem;
  max-width:720px; margin:0 auto; position:relative; text-align:left;
}
.thesis-box p { color:rgba(255,255,255,0.85); font-size:0.95rem; line-height:1.7; font-style:italic; }
.hero-nav-hint {
  position:absolute; bottom:2rem; left:50%; transform:translateX(-50%);
  color:rgba(255,255,255,0.4); font-size:0.75rem; letter-spacing:1px; text-transform:uppercase;
}

/* TAB SECTIONS */
.tab-section { display:none; padding-top:60px; min-height:calc(100vh - 60px); }
.tab-section.active { display:block; }

/* CONTAINERS */
.container { max-width:1200px; margin:0 auto; padding:0 2rem; }
.section-pad { padding:4rem 0; }
.section-label { font-size:0.72rem; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:0.5rem; display:block; }
.section-title { font-family:'Playfair Display',serif; font-weight:700; font-size:clamp(1.8rem,3vw,2.4rem); color:var(--navy); margin-bottom:1rem; line-height:1.2; }
.section-desc { font-size:1rem; color:var(--gray-dark); line-height:1.7; max-width:700px; margin-bottom:2rem; }

/* BG */
.bg-white { background:white; }
.bg-light { background:var(--off-white); }
.bg-navy { background:var(--navy); color:white; }
.bg-navy .section-title { color:white; }
.bg-navy .section-label { color:var(--gold-light); }
.bg-navy .section-desc { color:rgba(255,255,255,0.75); }

/* CARDS */
.card { background:white; border-radius:12px; padding:1.8rem; border:1px solid var(--gray); box-shadow:0 2px 12px rgba(0,0,0,0.05); }
.card-red { border-top:4px solid var(--red); }
.card h3 { font-family:'Playfair Display',serif; font-size:1.1rem; color:var(--navy); margin-bottom:0.8rem; font-weight:700; }

/* GRIDS */
.grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
.grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5rem; }
.grid-4 { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; }

/* STAT BOXES */
.stat-box { background:white; border-radius:10px; padding:1.5rem; border:1px solid var(--gray); text-align:center; }
.stat-box .stat-val { font-family:'DM Mono',monospace; font-size:2rem; font-weight:500; color:var(--navy); display:block; }
.stat-box .stat-val.red { color:var(--red); }
.stat-box .stat-val.green { color:var(--green); }
.stat-box .stat-lbl { font-size:0.78rem; text-transform:uppercase; letter-spacing:1px; color:var(--gray-mid); margin-top:4px; display:block; }
.stat-box .stat-desc { font-size:0.82rem; color:var(--gray-dark); margin-top:8px; line-height:1.5; }

/* PHASES */
.phases { display:grid; grid-template-columns:repeat(3,1fr); gap:0; border-radius:12px; overflow:hidden; border:1px solid var(--gray); }
.phase { padding:2rem; position:relative; }
.phase-1 { background:var(--navy-dark); }
.phase-2 { background:var(--navy); border-left:1px solid rgba(255,255,255,0.1); border-right:1px solid rgba(255,255,255,0.1); }
.phase-3 { background:var(--navy-light); }
.phase-num { font-family:'Playfair Display',serif; font-size:3rem; font-weight:900; color:rgba(255,255,255,0.1); line-height:1; margin-bottom:0.5rem; }
.phase-tag { font-size:0.7rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--gold-light); margin-bottom:0.5rem; display:block; }
.phase h3 { color:white; font-family:'Playfair Display',serif; font-size:1.2rem; margin-bottom:0.8rem; }
.phase p { color:rgba(255,255,255,0.75); font-size:0.9rem; line-height:1.6; }

/* AUC BARS */
.auc-bars { display:flex; flex-direction:column; gap:0.8rem; }
.auc-row { display:flex; align-items:center; gap:1rem; }
.auc-label { width:160px; font-size:0.85rem; font-weight:500; color:var(--navy); flex-shrink:0; }
.auc-bar-wrap { flex:1; background:var(--gray-light); border-radius:4px; height:32px; overflow:hidden; }
.auc-bar { height:100%; border-radius:4px; display:flex; align-items:center; padding-left:10px; font-family:'DM Mono',monospace; font-size:0.82rem; font-weight:500; color:white; }
.auc-bar.selected { background:var(--navy); }
.auc-bar.alt { background:var(--gray-mid); }
.auc-bar.weak { background:#bbb; }
.auc-badge { background:var(--red); color:white; font-size:0.65rem; font-weight:700; letter-spacing:1px; text-transform:uppercase; padding:3px 8px; border-radius:10px; flex-shrink:0; }

/* KELLY */
.kelly-equation { background:var(--navy-dark); border-radius:12px; padding:2rem; text-align:center; margin:1.5rem 0; border:1px solid rgba(255,255,255,0.1); }
.kelly-equation .eq-label { font-size:0.72rem; letter-spacing:2px; text-transform:uppercase; color:var(--gold-light); margin-bottom:0.8rem; display:block; }
.kelly-equation .eq-full { font-family:'DM Mono',monospace; font-size:1.4rem; color:white; margin-bottom:0.5rem; }
.kelly-equation .eq-simple { font-size:0.9rem; color:rgba(255,255,255,0.6); font-style:italic; }
.kelly-vars { display:grid; grid-template-columns:repeat(2,1fr); gap:0.8rem; margin-top:1.5rem; }
.kelly-var { background:white; border-radius:8px; padding:1rem; border-left:3px solid var(--navy); }
.kelly-var .kv-sym { font-family:'DM Mono',monospace; font-size:0.9rem; font-weight:500; color:var(--navy); }
.kelly-var .kv-desc { font-size:0.82rem; color:var(--gray-dark); margin-top:3px; }
.kelly-var .kv-val { font-size:0.8rem; color:var(--red); font-weight:600; margin-top:2px; }

/* TABLES */
.table-wrap { overflow-x:auto; border-radius:10px; border:1px solid var(--gray); }
table { width:100%; border-collapse:collapse; font-size:0.85rem; }
thead tr { background:var(--navy); color:white; }
thead th { padding:12px 14px; text-align:left; font-size:0.75rem; font-weight:600; letter-spacing:0.5px; text-transform:uppercase; white-space:nowrap; }
tbody tr:nth-child(even) { background:var(--off-white); }
tbody tr:nth-child(odd) { background:white; }
tbody tr:hover { background:#e8eef6; }
tbody td { padding:10px 14px; color:var(--text); white-space:nowrap; }
.badge-trade { background:var(--green-light); color:var(--green); font-size:0.72rem; font-weight:700; padding:3px 10px; border-radius:12px; }
.badge-skip { background:#fee2e2; color:var(--red-dark); font-size:0.72rem; font-weight:700; padding:3px 10px; border-radius:12px; }
.badge-excluded { background:#fef3c7; color:#92400e; font-size:0.72rem; font-weight:700; padding:3px 10px; border-radius:12px; }
.mono { font-family:'DM Mono',monospace; }
.outcome-win { color:var(--green); font-weight:700; }
.outcome-loss { color:var(--red); font-weight:700; }
.outcome-stop { color:#d97706; font-weight:700; }
.pnl-pos { color:var(--green); font-family:'DM Mono',monospace; font-weight:600; }
.pnl-neg { color:var(--red); font-family:'DM Mono',monospace; font-weight:600; }

/* PIPELINE */
.pipeline { display:flex; align-items:stretch; gap:0; border-radius:12px; overflow:hidden; border:1px solid var(--gray); }
.pipeline-step { flex:1; padding:1.8rem 1.4rem; background:white; border-right:1px solid var(--gray); }
.pipeline-step:last-child { border-right:none; }
.pipeline-step:nth-child(1) { border-top:4px solid var(--red); }
.pipeline-step:nth-child(2) { border-top:4px solid var(--navy); }
.pipeline-step:nth-child(3) { border-top:4px solid var(--gold); }
.ps-num { font-family:'Playfair Display',serif; font-size:2.5rem; font-weight:900; color:var(--gray-light); line-height:1; margin-bottom:0.3rem; }
.ps-title { font-weight:700; font-size:0.95rem; color:var(--navy); margin-bottom:0.6rem; }
.ps-desc { font-size:0.83rem; color:var(--gray-dark); line-height:1.5; }
.ps-output { margin-top:0.8rem; background:var(--gray-light); border-radius:6px; padding:0.5rem 0.8rem; font-size:0.78rem; color:var(--navy); font-weight:500; font-family:'DM Mono',monospace; }

/* QUOTE / INFO */
.quote-box { background:var(--off-white); border-left:4px solid var(--red); border-radius:0 8px 8px 0; padding:1.2rem 1.5rem; margin:1.2rem 0; }
.quote-box p { font-size:0.9rem; color:var(--gray-dark); line-height:1.6; font-style:italic; }
.quote-box .cite { font-size:0.78rem; color:var(--gray-mid); margin-top:0.5rem; font-style:normal; font-weight:600; }
.info-box { background:var(--off-white); border:1px solid var(--gray); border-radius:10px; padding:1.2rem 1.5rem; margin:1rem 0; }
.info-box h4 { font-weight:700; color:var(--navy); font-size:0.9rem; margin-bottom:0.5rem; }
.info-box p, .info-box li { font-size:0.85rem; color:var(--gray-dark); line-height:1.6; }
.info-box ul { padding-left:1.2rem; }

/* SOURCE */
.source-item { background:white; border-radius:8px; padding:1rem 1.2rem; border:1px solid var(--gray); border-left:3px solid var(--navy); margin-bottom:0.6rem; }
.source-item .src-title { font-size:0.88rem; font-weight:600; color:var(--navy); margin-bottom:3px; }
.source-item .src-cite { font-size:0.8rem; color:var(--gray-dark); line-height:1.4; }
.source-item a { color:var(--red); text-decoration:none; font-size:0.78rem; }
.source-item a:hover { text-decoration:underline; }

/* TEAM */
.team-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; }
.team-card { background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.15); border-radius:10px; padding:1.5rem 1rem; text-align:center; }
.team-avatar { width:56px; height:56px; background:var(--red); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Playfair Display',serif; font-weight:700; font-size:1.3rem; color:white; margin:0 auto 0.8rem; }
.team-name { font-weight:600; color:white; font-size:0.9rem; }
.team-role { font-size:0.75rem; color:rgba(255,255,255,0.5); margin-top:3px; }

/* AI BOX */
.ai-box { background:linear-gradient(135deg,var(--navy-dark),#1a3a6e); border-radius:12px; padding:2rem; border:1px solid rgba(255,255,255,0.1); border-left:4px solid var(--gold-light); color:white; }
.ai-box h3 { font-family:'Playfair Display',serif; font-size:1.2rem; color:var(--gold-light); margin-bottom:0.8rem; }
.ai-box p { font-size:0.9rem; color:rgba(255,255,255,0.8); line-height:1.7; }
.ai-tags { display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:1rem; }
.ai-tag { background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2); color:rgba(255,255,255,0.8); font-size:0.75rem; padding:4px 12px; border-radius:20px; }

/* TAGS */
.tag { display:inline-block; background:var(--off-white); border:1px solid var(--gray); border-radius:20px; padding:4px 12px; font-size:0.75rem; font-weight:600; color:var(--navy); margin:2px; }
.tag.red { background:#fee2e2; border-color:#fca5a5; color:var(--red-dark); }
.tag.green { background:var(--green-light); border-color:#86efac; color:var(--green); }

/* DIVIDER */
.divider { height:1px; background:linear-gradient(90deg,transparent,var(--gray),transparent); margin:2rem 0; }

/* FOOTER */
footer { background:var(--navy-dark); border-top:3px solid var(--red); padding:2rem; text-align:center; }
footer p { color:rgba(255,255,255,0.5); font-size:0.8rem; margin-bottom:0.3rem; }
footer a { color:rgba(255,255,255,0.7); text-decoration:none; }

/* ── VISUALIZATIONS ────────────────────────────────── */

/* Feature Importance Chart */
.fi-chart-wrap { background:white; border-radius:12px; border:1px solid var(--gray); padding:1.5rem; overflow:hidden; }
.fi-row { display:flex; align-items:center; gap:0.8rem; margin-bottom:6px; }
.fi-rank { width:28px; font-size:0.72rem; color:var(--gray-mid); font-family:'DM Mono',monospace; text-align:right; flex-shrink:0; }
.fi-name { width:170px; font-size:0.78rem; font-weight:500; color:var(--navy); flex-shrink:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.fi-bar-wrap { flex:1; background:var(--gray-light); border-radius:3px; height:20px; position:relative; cursor:pointer; }
.fi-bar { height:100%; border-radius:3px; display:flex; align-items:center; padding-left:6px; font-family:'DM Mono',monospace; font-size:0.7rem; color:white; font-weight:500; transition:opacity 0.2s; }
.fi-bar:hover { opacity:0.85; }
.fi-bar.top { background:var(--navy); }
.fi-bar.regime { background:var(--green); }
.fi-bar.normal { background:#6b8cba; }
.fi-tooltip { position:absolute; top:-36px; left:50%; transform:translateX(-50%); background:var(--navy-dark); color:white; font-size:0.72rem; padding:4px 10px; border-radius:6px; white-space:nowrap; pointer-events:none; opacity:0; transition:opacity 0.2s; z-index:10; }
.fi-bar-wrap:hover .fi-tooltip { opacity:1; }
.fi-legend { display:flex; gap:1.5rem; margin-bottom:1rem; font-size:0.78rem; }
.fi-legend-item { display:flex; align-items:center; gap:6px; }
.fi-legend-dot { width:12px; height:12px; border-radius:3px; }

/* Decision Tree */
.tree-wrap { background:var(--navy-dark); border-radius:12px; padding:2rem; overflow-x:auto; }
.tree-container { min-width:700px; position:relative; }
.tree-svg { width:100%; }
.tree-node-box { fill:var(--navy); stroke:rgba(255,255,255,0.2); stroke-width:1; rx:8; ry:8; }
.tree-node-box.high { fill:#1a5c32; }
.tree-node-box.low { fill:#3d4a5c; }
.tree-node-box.root { fill:var(--red-dark); }
.tree-line { stroke:rgba(255,255,255,0.3); stroke-width:1.5; fill:none; }
.tree-text-title { fill:white; font-family:'DM Sans',sans-serif; font-weight:600; font-size:11px; }
.tree-text-sub { fill:rgba(255,255,255,0.7); font-family:'DM Mono',monospace; font-size:9px; }
.tree-text-prob { font-family:'DM Mono',monospace; font-weight:700; font-size:12px; }
.tree-branch-label { fill:rgba(255,255,255,0.5); font-family:'DM Sans',sans-serif; font-size:9px; }

/* Regime Timeline */
.regime-wrap { background:var(--navy-dark); border-radius:12px; padding:2rem; overflow-x:auto; }
.regime-timeline { min-width:600px; position:relative; }

/* RESPONSIVE */
@media (max-width:900px) {
  .grid-2,.grid-3,.grid-4,.phases,.team-grid,.pipeline { grid-template-columns:1fr; flex-direction:column; }
  .nav-links { display:none; }
  .hamburger { display:flex; }
  .hero-metrics { flex-wrap:wrap; }
  .kelly-vars { grid-template-columns:1fr; }
  .fi-name { width:120px; }
}
@media (max-width:600px) {
  .hero-metric { flex:0 0 45%; }
  .grid-4 { grid-template-columns:1fr 1fr; }
}
</style>
</head>
